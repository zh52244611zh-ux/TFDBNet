import torch
import torch.nn as nn
import torch.nn.functional as F


class PatchEmbed1d(nn.Module):
    """1D Patch Embedding with automatic padding."""

    def __init__(self, input_channels=12, patch_size=16, embed_dim=256):
        super().__init__()
        self.patch_size = patch_size
        self.proj = nn.Conv1d(input_channels, embed_dim, kernel_size=patch_size, stride=patch_size)

    def forward(self, x):
        # x: (B, C, L)
        seq_len = x.size(-1)
        # Calculate padding to make divisible by patch_size
        pad_len = (self.patch_size - seq_len % self.patch_size) % self.patch_size
        if pad_len > 0:
            x = F.pad(x, (0, pad_len))

        x = self.proj(x)  # (B, E, N)
        x = x.permute(0, 2, 1)  # (B, N, E)
        return x


class PositionalEncoding(nn.Module):
    """Fixed: Slices for shorter seqs, Interpolates only for longer seqs."""

    def __init__(self, max_num_tokens=1001, embed_dim=256, dropout=0.1):
        super().__init__()
        self.max_num_tokens = max_num_tokens
        # Use register_buffer so it's saved in state_dict but not updated by optimizer
        self.register_buffer('pos_embed', torch.zeros(1, max_num_tokens, embed_dim))

        # Standard sin/cos initialization is often better than zeros for training stability
        # But learnable (nn.Parameter) is also fine. Keeping your nn.Parameter style:
        self.pos_embed = nn.Parameter(torch.zeros(1, max_num_tokens, embed_dim))
        nn.init.trunc_normal_(self.pos_embed, std=0.02)  # Initialize weights properly

        self.dropout = nn.Dropout(p=dropout)

    def forward(self, x):
        # x: (B, N, E)
        actual_len = x.size(1)

        if actual_len <= self.pos_embed.size(1):
            # Correct logic: Slice. Preserve absolute timing.
            pos = self.pos_embed[:, :actual_len, :]
        else:
            # Fallback logic: Interpolate. (Only happens if input > max_trained_len)
            print(f"Warning: Input length {actual_len} > max position {self.pos_embed.size(1)}. Interpolating.")
            pos = self.pos_embed.permute(0, 2, 1)
            pos = F.interpolate(pos, size=actual_len, mode='linear', align_corners=False)
            pos = pos.permute(0, 2, 1)

        x = x + pos
        return self.dropout(x)


class ViT1d(nn.Module):
    def __init__(self, input_channels=12, max_seq_len=16000, patch_size=16, embed_dim=256,
                 num_heads=8, num_layers=8, mlp_dim=512, num_classes=9, dropout=0.1):
        super(ViT1d, self).__init__()

        self.patch_embed = PatchEmbed1d(input_channels, patch_size, embed_dim)

        # Calculate max tokens
        max_num_patches = (max_seq_len // patch_size) + 1  # +1 for buffer or padding
        self.cls_token = nn.Parameter(torch.zeros(1, 1, embed_dim))
        nn.init.trunc_normal_(self.cls_token, std=0.02)

        self.pos_embed = PositionalEncoding(max_num_patches + 1, embed_dim, dropout)  # +1 for CLS

        # Use PyTorch's native layer for speed and Pre-Norm (norm_first=True)
        encoder_layer = nn.TransformerEncoderLayer(
            d_model=embed_dim,
            nhead=num_heads,
            dim_feedforward=mlp_dim,
            dropout=dropout,
            activation='gelu',
            batch_first=True,
            norm_first=True  # Important: Pre-Norm for stability
        )
        self.encoder = nn.TransformerEncoder(encoder_layer, num_layers=num_layers)

        self.norm = nn.LayerNorm(embed_dim)

        self.head = nn.Sequential(
            nn.Linear(embed_dim, mlp_dim),
            nn.GELU(),
            nn.Dropout(dropout),
            nn.Linear(mlp_dim, num_classes)
        )

    def forward(self, x):
        # x: (Batch, Channel, Length)
        B = x.shape[0]

        x = self.patch_embed(x)  # (B, N, E)

        # Concat CLS token
        cls_tokens = self.cls_token.expand(B, -1, -1)
        x = torch.cat((cls_tokens, x), dim=1)

        # Add Positional Encoding
        x = self.pos_embed(x)

        # Transformer Encoder
        x = self.encoder(x)

        # Final Norm (needed because of Pre-Norm architecture)
        x = self.norm(x)

        # Extract CLS token
        cls_out = x[:, 0]

        # MLP Head
        logits = self.head(cls_out)

        # --- 修复部分开始 ---
        # 创建一个假的 attention 输出以通过 "logits, _ = net(data)" 检查
        # 形状通常设为 (Batch, 1) 或者与之前的模型保持一致
        dummy_attention = torch.ones(B, 1, device=x.device)

        return logits, dummy_attention
        # --- 修复部分结束 ---


