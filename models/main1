    def train_epoch(self, train_loader, net, criterion, optimizer, epoch, fold=0):
        net.train()
        running_loss = 0.0
        all_outputs = []
        all_labels = []

        for data, labels in tqdm(train_loader, desc=f'Epoch {epoch}'):
            data, labels = data.to(self.device), labels.to(self.device)
            optimizer.zero_grad()
            logits, _ = net(data)
            loss = criterion(logits, labels)
            loss.backward()
            torch.nn.utils.clip_grad_norm_(net.parameters(), max_norm=self.args.grad_clip)
            optimizer.step()
            running_loss += loss.item()
            outputs = torch.sigmoid(logits)
            # === 新增：强制清理 NaN 和 Inf ===
            if torch.isnan(outputs).any() or torch.isinf(outputs).any():
                logging.warning(f"NaN or Inf detected in model output at epoch {epoch}")
                outputs = torch.nan_to_num(outputs, nan=0.0, posinf=1.0, neginf=0.0)
            # ====================================
            all_outputs.append(outputs.detach().cpu().numpy())
            all_labels.append(labels.detach().cpu().numpy())

        avg_loss = running_loss / len(train_loader)
        all_outputs = np.vstack(all_outputs)
        all_labels = np.vstack(all_labels)
        f1s = cal_f1s(all_labels, all_outputs)
        avg_f1 = np.mean(f1s)

        self.writer.add_scalar('Loss/Train', avg_loss, epoch)
        self.writer.add_scalar('F1/Train', avg_f1, epoch)
        for i, f1 in enumerate(f1s):
            self.writer.add_scalar(f'F1/Train/Class_{self.class_names[i]}', f1, epoch)
        for param_group in optimizer.param_groups:
            self.writer.add_scalar('LR', param_group['lr'], epoch)

        self.train_losses.append(avg_loss)
        self.train_f1s.append(avg_f1)

        # Log metrics in tabular format
        with open(self.metrics_log_path, 'a') as f:
            f.write(f"{fold:>4} | {epoch:>5} | {avg_loss:>10.4f} | {avg_f1:>8.4f} | {'':>8} | {'':>6} | {'':>6}\n")

        return avg_loss, avg_f1

    def validate(self, val_loader, net, criterion, epoch, phase='val', fold=0):
        net.eval()
        running_loss = 0.0
        all_outputs = []
        all_labels = []

        with torch.no_grad():
            for data, labels in val_loader:
                data, labels = data.to(self.device), labels.to(self.device)
                logits, _ = net(data)
                loss = criterion(logits, labels)
                running_loss += loss.item()
                outputs = torch.sigmoid(logits)
                # === 新增：强制清理 NaN 和 Inf ===
                if torch.isnan(outputs).any() or torch.isinf(outputs).any():
                    logging.warning(f"NaN or Inf detected in model output at epoch {epoch}")
                    outputs = torch.nan_to_num(outputs, nan=0.0, posinf=1.0, neginf=0.0)
                # ====================================
                all_outputs.append(outputs.detach().cpu().numpy())
                all_labels.append(labels.detach().cpu().numpy())

        avg_loss = running_loss / len(val_loader)
        all_outputs = np.vstack(all_outputs)
        all_labels = np.vstack(all_labels)
        f1s = cal_f1s(all_labels, all_outputs)
        avg_f1 = np.mean(f1s)
        aucs = cal_aucs(all_labels, all_outputs)
        avg_auc = np.mean(aucs)
        precision, recall, f1_per_class, _ = precision_recall_fscore_support(
            all_labels, all_outputs > 0.5, average=None, labels=range(len(self.class_names))
        )

        self.writer.add_scalar(f'Loss/{phase}', avg_loss, epoch)
        self.writer.add_scalar(f'F1/{phase}', avg_f1, epoch)
        self.writer.add_scalar(f'AUC/{phase}', avg_auc, epoch)
        for i, (p, r, f) in enumerate(zip(precision, recall, f1_per_class)):
            self.writer.add_scalar(f'Precision/{phase}/Class_{self.class_names[i]}', p, epoch)
            self.writer.add_scalar(f'Recall/{phase}/Class_{self.class_names[i]}', r, epoch)
            self.writer.add_scalar(f'F1/{phase}/Class_{self.class_names[i]}', f, epoch)

        self.val_losses.append(avg_loss)
        self.val_f1s.append(avg_f1)

        # Complete metric line for validation
        with open(self.metrics_log_path, 'a') as f:
            f.write(
                f"{fold:>4} | {epoch:>5} | {'':>10} | {'':>8} | {avg_loss:>8.4f} | {avg_f1:>6.4f} | {avg_auc:>6.4f}\n")

        if phase == 'test':
            # 执行全面的可视化
            figures = self.comprehensive_visualization(all_labels, all_outputs, net, val_loader, fold)

            # Per-class metrics table
            cm = [confusion_matrix(all_labels[:, i], (all_outputs[:, i] > 0.5).astype(int)) for i in
                  range(len(self.class_names))]
            per_class_acc = [np.diag(cm[i]) / np.sum(cm[i], axis=1) if np.sum(cm[i], axis=1).any() else np.array([0.0])
                             for i in range(len(self.class_names))]
            with open(self.metrics_log_path, 'a') as f:
                f.write(f"\n=== Fold {fold} Test Results ===\n")
                f.write(f"Loss: {avg_loss:.4f} | F1: {avg_f1:.4f} | AUC: {avg_auc:.4f}\n")
                f.write(f"Visualizations saved to: {self.current_result_dir}\n")
                f.write("\n=== Per-Class Metrics ===\n")
                f.write("Class | Name               | Accuracy | Precision | Recall | F1\n")
                for i, acc in enumerate(per_class_acc):
                    acc_val = acc[0] if acc.size > 0 else 0.0
                    f.write(
                        f"{i:>5} | {self.class_names[i]:>15} | {acc_val:>8.4f} | {precision[i]:>9.4f} | {recall[i]:>6.4f} | {f1_per_class[i]:>6.4f}\n")

        return avg_loss, avg_f1, avg_auc, all_outputs, all_labels

    def early_stopping(self, current_metric, patience=None):
        if patience is None:
            patience = self.args.early_stopping
        if current_metric > self.best_metric:
            self.best_metric = current_metric
            self.epochs_no_improve = 0
            return False
        else:
            self.epochs_no_improve += 1
            if self.epochs_no_improve >= patience:
                with open(self.metrics_log_path, 'a') as f:
                    f.write(f"Early stopping triggered after {self.epochs_no_improve} epochs without improvement\n")
                return True
            return False

    def save_checkpoint(self, net, optimizer, scheduler, epoch, is_best=False, fold=0):
        state = {
            'epoch': epoch,
            'state_dict': net.state_dict(),
            'optimizer': optimizer.state_dict(),
            'scheduler': scheduler.state_dict(),
            'best_metric': self.best_metric,
            'args': vars(self.args)
        }
        filename = f'checkpoint_fold{fold}.pth' if not is_best else f'best_model_fold{fold}.pth'
        torch.save(state, os.path.join(self.args.log_dir, 'models', filename))

    def load_checkpoint(self, net, optimizer, scheduler, fold=0):
        filename = os.path.join(self.args.log_dir, 'models', f'best_model_fold{fold}.pth')
        if os.path.exists(filename):
            checkpoint = torch.load(filename, map_location=self.device)
            net.load_state_dict(checkpoint['state_dict'])
            if optimizer is not None:
                optimizer.load_state_dict(checkpoint['optimizer'])
            if scheduler is not None:
                scheduler.load_state_dict(checkpoint['scheduler'])
            self.best_metric = checkpoint['best_metric']
            return checkpoint['epoch']
        return 0


def get_class_distribution(dataset, fold, metrics_log_path, class_names):
    all_labels = []
    for i in range(len(dataset)):
        try:
            _, label = dataset[i]
            all_labels.append(label.cpu().numpy())
        except Exception as e:
            with open(metrics_log_path, 'a') as f:
                f.write(f"Error in get_class_distribution for fold {fold}, index {i}: {e}\n")
            continue
    all_labels = np.vstack(all_labels) if all_labels else np.zeros((0, len(class_names)))
    label_counts = all_labels.sum(axis=0)
    total_samples = len(dataset)
    with open(metrics_log_path, 'a') as f:
        f.write(f"\n=== Fold {fold} Training Set Class Distribution ===\n")
        f.write("Class | Name               | Samples | Proportion\n")
        for class_id, count in enumerate(label_counts):
            proportion = count / total_samples if total_samples > 0 else 0.0
            class_name = class_names[class_id]
            f.write(f"{class_id:>5} | {class_name:>15} | {int(count):>7} | {proportion:>10.4f}\n")
        f.write("\n")


def train_single_fold(args, train_dataset, val_dataset, test_dataset, device, fold=0, metrics_log_path=None):
    class_names = ['NORM', 'ABNORM']
    trainer = Trainer(args, device, metrics_log_path, class_names)

    try:
        # train_loader = DataLoader(train_dataset, batch_size=args.batch_size, shuffle=True, num_workers=args.num_workers,
        #                           pin_memory=True)
        train_loader = DataLoader(train_dataset, batch_size=args.batch_size, shuffle=True, num_workers=args.num_workers,
                                  pin_memory=True, drop_last=True)
        val_loader = DataLoader(val_dataset, batch_size=args.batch_size, shuffle=False, num_workers=args.num_workers,
                                pin_memory=True)
        test_loader = DataLoader(test_dataset, batch_size=args.batch_size, shuffle=False, num_workers=args.num_workers,
                                 pin_memory=True)
    except Exception as e:
        with open(metrics_log_path, 'a') as f:
            f.write(f"Failed to create data loaders for fold {fold}: {e}\n")
        raise

    nleads = 12 if args.leads == 'all' else len(args.leads.split(','))
    # net = LSTMECG(input_channels=nleads).to(device)
    # net = resnet18_enhanced(input_channels=nleads).to(device)
    net = DualBranchResNet(input_channels=nleads).to(device)
    params = trainer.count_parameters(net)

    with open(metrics_log_path, 'a') as f:
        f.write(f"\n=== Fold {fold} ===\n")
        f.write(f"Model: ImprovedECGModel\n")
        f.write(f"Parameters: {params:.2f}M\n")

    optimizer = torch.optim.Adam(net.parameters(), lr=args.lr, weight_decay=args.weight_decay)
    scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='min', factor=0.5, patience=5, min_lr=1e-6)

    if args.class_weight:
        class_weights = trainer.calculate_class_weights(train_dataset)
        criterion = FocalLoss(alpha=class_weights, gamma=2.0)
        with open(metrics_log_path, 'a') as f:
            f.write(f"Class weights: {class_weights.cpu().numpy()}\n")
    else:
        criterion = nn.BCEWithLogitsLoss()

    # Log class distribution
    get_class_distribution(train_dataset, fold, metrics_log_path, class_names)

    start_epoch = 0
    if args.resume:
        start_epoch = trainer.load_checkpoint(net, optimizer, scheduler, fold)

    for epoch in range(start_epoch, args.epochs):
        train_loss, train_f1 = trainer.train_epoch(train_loader, net, criterion, optimizer, epoch, fold)
        val_loss, val_f1, val_auc, _, _ = trainer.validate(val_loader, net, criterion, epoch, 'val', fold)
        scheduler.step(val_loss)

        if trainer.early_stopping(val_f1):
            break

        is_best = val_f1 > trainer.best_metric
        trainer.save_checkpoint(net, optimizer, scheduler, epoch, is_best, fold)

    # 训练结束后绘制学习曲线
    trainer.plot_learning_curves(fold)

    trainer.load_checkpoint(net, None, None, fold)
    test_loss, test_f1, test_auc, test_outputs, test_labels = trainer.validate(test_loader, net, criterion, 0, 'test',
                                                                               fold)

    history = {
        'train_loss': trainer.train_losses,
        'val_loss': trainer.val_losses,
        'train_f1': trainer.train_f1s,
        'val_f1': trainer.val_f1s,
        'test_metrics': {'loss': test_loss, 'f1': test_f1, 'auc': test_auc}
    }
    with open(os.path.join(args.log_dir, f'history_fold_{fold}.json'), 'w') as f:
        json.dump(history, f, indent=2)

    trainer.writer.close()
    return test_f1, test_auc


def kfold_cross_validation(args, full_dataset, device, metrics_log_path):
    if args.k_fold < 2:
        raise ValueError(f"Number of folds (k_fold={args.k_fold}) must be at least 2 for K-Fold cross-validation.")

    indices = list(range(len(full_dataset)))
    train_val_indices, test_indices = train_test_split(indices, test_size=args.test_size, random_state=args.seed)
    test_dataset = Subset(full_dataset, test_indices)

    kfold = KFold(n_splits=args.k_fold, shuffle=True, random_state=args.seed)
    fold_results = {'f1': [], 'auc': []}

    for fold, (train_idx, val_idx) in enumerate(kfold.split(train_val_indices)):
        print(f'Starting fold {fold + 1}/{args.k_fold}')
        train_indices = [train_val_indices[i] for i in train_idx]
        val_indices = [train_val_indices[i] for i in val_idx]
        train_subset = Subset(full_dataset, train_indices)
        val_subset = Subset(full_dataset, val_indices)
        test_f1, test_auc = train_single_fold(args, train_subset, val_subset, test_dataset, device, fold,
                                              metrics_log_path)
        fold_results['f1'].append(test_f1)
        fold_results['auc'].append(test_auc)

    with open(metrics_log_path, 'a') as f:
        f.write("\n=== Cross-Validation Summary ===\n")
        f.write(f"f1: Mean = {np.mean(fold_results['f1']):.4f}, Std = {np.std(fold_results['f1']):.4f}\n")
        f.write(f"auc: Mean = {np.mean(fold_results['auc']):.4f}, Std = {np.std(fold_results['auc']):.4f}\n")

    with open(os.path.join(args.log_dir, 'cv_results.json'), 'w') as f:
        json.dump(fold_results, f, indent=2)

    return fold_results


def main():
    args = parse_args()
    device = torch.device('cuda:0' if args.use_gpu and torch.cuda.is_available() else 'cpu')

    # timestamp = datetime.datetime.now().strftime('%H_%M')
    # args.log_dir = os.path.join(args.log_dir, f'{args.experiment}_{timestamp}')
    args.log_dir = os.path.join(args.log_dir, args.result_dir)
    os.makedirs(args.log_dir, exist_ok=True)

    metrics_log_path = os.path.join(args.log_dir, f"{args.run_description}.log")
    mode = f"{args.k_fold}-Fold Cross-Validation" if args.k_fold >= 2 else "Single Train/Val"

    with open(metrics_log_path, 'w') as f:
        f.write(f"Model: DualBranchResNet\n")
        f.write(f"Dataset: PTB-XL (2 classes)\n")
        f.write(f"Mode: {mode}\n")
        f.write(f"Hyperparameters: {vars(args)}\n")
        f.write("\n=== Training Metrics ===\n")
        f.write("Fold | Epoch | Train Loss | Train F1 | Val Loss | Val F1 | Val AUC\n")
        f.write("=" * 60 + "\n")

    with open(os.path.join(args.log_dir, 'args.json'), 'w') as f:
        json.dump(vars(args), f, indent=2)

    # ======================== 新增参数使用 ========================
    # processed_dir：预处理后 .npy 文件所在文件夹（必须）
    processed_dir = args.processed_dir

    # label_csv：标签文件路径，如果未指定则自动在 processed_dir 中查找
    label_csv = args.label_csv or os.path.join(processed_dir, 'labels_2class.csv')

    # 路径检查，提前报错避免后续卡住
    if not os.path.exists(processed_dir):
        raise FileNotFoundError(f"预处理文件夹不存在，请检查 --processed-dir 参数:\n{processed_dir}")
    if not os.path.exists(label_csv):
        raise FileNotFoundError(f"标签文件不存在，请检查路径:\n{label_csv}")

    logging.info(f"使用预处理文件夹: {processed_dir}")
    logging.info(f"使用标签文件: {label_csv}")

    try:
        if args.phase == 'test':
            if not os.path.exists(args.model_path):
                raise FileNotFoundError(f"Model path {args.model_path} does not exist")

            test_dataset = ECGDataset(
                phase='test',
                processed_dir=processed_dir,
                label_csv=label_csv,
                folds=None,  # test 模式通常不限 fold，或根据需要指定
                leads=args.leads,
                signal_length=args.signal_length,
                apply_augmentation=False
            )

            test_loader = DataLoader(test_dataset, batch_size=args.batch_size, shuffle=False,
                                     num_workers=args.num_workers, pin_memory=True)

            nleads = 12 if args.leads == 'all' else len(args.leads.split(','))
            net = DualBranchResNet(input_channels=nleads).to(device)
            net.load_state_dict(torch.load(args.model_path, map_location=device)['state_dict'])

            class_names = ['NORM', 'ABNORM']
            trainer = Trainer(args, device, metrics_log_path, class_names)

            criterion = nn.BCEWithLogitsLoss()
            test_loss, test_f1, test_auc, _, _ = trainer.validate(test_loader, net, criterion, 0, 'test', 0)

            with open(metrics_log_path, 'a') as f:
                f.write(f"\n=== Test Results ===\n")
                f.write(f"Loss: {test_loss:.4f} | F1: {test_f1:.4f} | AUC: {test_auc:.4f}\n")

        else:
            # ======================== 训练 / 验证 / K-Fold ========================
            if args.k_fold >= 2:
                # K-Fold 交叉验证：使用全部数据，按 strat_fold 分
                full_dataset = ECGDataset(
                    phase='all',  # 自定义 phase，表示加载全部
                    processed_dir=processed_dir,
                    label_csv=label_csv,
                    folds=None,  # 不筛选 fold，kfold 内部处理
                    leads=args.leads,
                    signal_length=args.signal_length,
                    apply_augmentation=False  # augmentation 在子集里控制
                )
                kfold_cross_validation(args, full_dataset, device, metrics_log_path)

            else:
                # 单次训练：手动划分或使用官方 strat_fold
                # 这里使用官方推荐划分：fold 0~7 训练，8 验证，9 测试
                train_dataset = ECGDataset(
                    phase='train',
                    processed_dir=processed_dir,
                    label_csv=label_csv,
                    folds=list(range(0, 8)),  # fold 0~7
                    leads=args.leads,
                    signal_length=args.signal_length,
                    apply_augmentation=True,
                    apply_class_weights=args.class_weight
                )

                val_dataset = ECGDataset(
                    phase='val',
                    processed_dir=processed_dir,
                    label_csv=label_csv,
                    folds=[8],  # fold 8
                    leads=args.leads,
                    signal_length=args.signal_length,
                    apply_augmentation=False
                )

                test_dataset = ECGDataset(
                    phase='test',
                    processed_dir=processed_dir,
                    label_csv=label_csv,
                    folds=[9],  # fold 9
                    leads=args.leads,
                    signal_length=args.signal_length,
                    apply_augmentation=False
                )

                test_f1, test_auc = train_single_fold(
                    args=args,
                    train_dataset=train_dataset,
                    val_dataset=val_dataset,
                    test_dataset=test_dataset,
                    device=device,
                    fold=0,
                    metrics_log_path=metrics_log_path
                )

                with open(metrics_log_path, 'a') as f:
                    f.write(f"\n=== Final Test Results ===\n")
                    f.write(f"F1: {test_f1:.4f} | AUC: {test_auc:.4f}\n")

    except Exception as e:
        logging.error(f"Training failed with error: {e}")
        import traceback
        traceback.print_exc()
        with open(metrics_log_path, 'a') as f:
            f.write(f"\n=== ERROR ===\n{traceback.format_exc()}\n")
        raise


if __name__ == "__main__":
    main()
