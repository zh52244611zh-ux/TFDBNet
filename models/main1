class FocalLoss(nn.Module):
    def __init__(self, alpha=None, gamma=2.0, reduction='mean'):
        super(FocalLoss, self).__init__()
        self.alpha = alpha
        self.gamma = gamma
        self.reduction = reduction

    def forward(self, inputs, targets):
        BCE_loss = nn.BCEWithLogitsLoss(reduction='none')(inputs, targets)
        pt = torch.exp(-BCE_loss)
        focal_loss = (1 - pt) ** self.gamma * BCE_loss
        if self.alpha is not None:
            if self.alpha.dim() == 1:
                self.alpha = self.alpha.unsqueeze(0)
            focal_loss = self.alpha * focal_loss
        if self.reduction == 'mean':
            return focal_loss.mean()
        elif self.reduction == 'sum':
            return focal_loss.sum()
        return focal_loss


class Trainer:
    def __init__(self, args, device, metrics_log_path, class_names):
        self.args = args
        self.device = device
        self.metrics_log_path = metrics_log_path
        self.class_names = class_names
        self.writer = SummaryWriter(log_dir=os.path.join(args.log_dir, 'tensorboard'))
        self.best_metric = 0
        self.epochs_no_improve = 0
        self.train_losses = []
        self.val_losses = []
        self.train_f1s = []
        self.val_f1s = []
        os.makedirs(os.path.join(args.log_dir, 'models'), exist_ok=True)

        # 创建结果目录
        self.results_base_dir = 'E:\\ecg-diagnosis-master\\results'
        self.current_result_dir = os.path.join(self.results_base_dir, args.result_dir)
        os.makedirs(self.current_result_dir, exist_ok=True)

    def count_parameters(self, net):
        return sum(p.numel() for p in net.parameters() if p.requires_grad) / 1e6

    def calculate_class_weights(self, dataset):
        all_labels = []
        for i in range(len(dataset)):
            _, label = dataset[i]
            all_labels.append(label.cpu().numpy())
        all_labels = np.vstack(all_labels)
        class_counts = all_labels.sum(axis=0) + 1e-6  # Avoid division by zero
        total = len(dataset)

        # 记录类别分布信息用于调试
        with open(self.metrics_log_path, 'a') as f:
            f.write(f"\n=== Class Distribution ===\n")
            f.write("Class | Count | Proportion\n")
            for i, count in enumerate(class_counts):
                proportion = count / total
                f.write(f"{i:>5} | {int(count):>5} | {proportion:>10.4f}\n")

        # 方法1: 使用中位数平衡（推荐，更稳定）
        median_count = np.median(class_counts)
        weights = median_count / class_counts

        # 应用缩放因子，使用更温和的缩放
        weights = weights ** self.args.weight_scale

        # 更严格的权重裁剪，避免极端值
        weights = np.clip(weights, 0.3, 3.0)  # 从[0.3, 10.0]改为[0.3, 3.0]

        # 可选：对权重进行归一化，使其均值为1
        weights = weights / np.mean(weights)

        # 记录详细的权重信息
        with open(self.metrics_log_path, 'a') as f:
            f.write(f"Raw inverse frequencies: {total / class_counts}\n")
            f.write(f"Final class weights: {weights}\n")
            f.write(f"Weight range: {np.min(weights):.3f} - {np.max(weights):.3f}\n")
            f.write(f"Weight ratio (max/min): {np.max(weights) / np.min(weights):.3f}\n")
            f.write(f"Weight mean: {np.mean(weights):.3f}\n")

        return torch.tensor(weights, dtype=torch.float32).to(self.device)

    def plot_learning_curves(self, fold=0):
        """绘制训练和验证损失曲线，用于检测过拟合"""
        if len(self.train_losses) == 0 or len(self.val_losses) == 0:
            return

        epochs = range(1, len(self.train_losses) + 1)

        # 创建子图
        fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(15, 5))

        # 绘制损失曲线
        ax1.plot(epochs, self.train_losses, 'b-', label='Training Loss', linewidth=2)
        ax1.plot(epochs, self.val_losses, 'r-', label='Validation Loss', linewidth=2)
        ax1.set_title(f'Training and Validation Loss (Fold {fold})')
        ax1.set_xlabel('Epochs')
        ax1.set_ylabel('Loss')
        ax1.legend()
        ax1.grid(True, alpha=0.3)

        # 标记最佳验证损失点
        best_val_epoch = np.argmin(self.val_losses)
        best_val_loss = self.val_losses[best_val_epoch]
        ax1.plot(best_val_epoch + 1, best_val_loss, 'ro', markersize=8,
                 label=f'Best Val Loss: {best_val_loss:.4f}')
        ax1.legend()

        # 绘制F1分数曲线
        if len(self.train_f1s) > 0 and len(self.val_f1s) > 0:
            ax2.plot(epochs, self.train_f1s, 'b-', label='Training F1', linewidth=2)
            ax2.plot(epochs, self.val_f1s, 'r-', label='Validation F1', linewidth=2)
            ax2.set_title(f'Training and Validation F1 Score (Fold {fold})')
            ax2.set_xlabel('Epochs')
            ax2.set_ylabel('F1 Score')
            ax2.legend()
            ax2.grid(True, alpha=0.3)

            # 标记最佳验证F1点
            best_val_f1_epoch = np.argmax(self.val_f1s)
            best_val_f1 = self.val_f1s[best_val_f1_epoch]
            ax2.plot(best_val_f1_epoch + 1, best_val_f1, 'ro', markersize=8,
                     label=f'Best Val F1: {best_val_f1:.4f}')
            ax2.legend()

        plt.tight_layout()

        # 保存图像
        curves_path = os.path.join(self.current_result_dir, f'learning_curves.png')
        plt.savefig(curves_path, dpi=300, bbox_inches='tight')
        plt.close()

        # 分析过拟合情况
        self._analyze_overfitting(fold)

        return fig

    def _analyze_overfitting(self, fold=0):
        """分析过拟合情况并记录到日志"""
        if len(self.train_losses) < 2 or len(self.val_losses) < 2:
            return

        # 计算训练和验证损失的最终差距
        final_train_loss = self.train_losses[-1]
        final_val_loss = self.val_losses[-1]
        loss_gap = final_val_loss - final_train_loss

        # 计算最佳验证损失后的性能变化
        best_val_epoch = np.argmin(self.val_losses)
        if best_val_epoch < len(self.val_losses) - 1:
            val_loss_after_best = self.val_losses[best_val_epoch + 1:]
            train_loss_after_best = self.train_losses[best_val_epoch + 1:]

            # 检查验证损失是否开始上升而训练损失继续下降
            val_increasing = any(val_loss_after_best[i] > val_loss_after_best[i - 1]
                                 for i in range(1, len(val_loss_after_best)))
            train_decreasing = any(train_loss_after_best[i] < train_loss_after_best[i - 1]
                                   for i in range(1, len(train_loss_after_best)))

            overfitting_detected = val_increasing and train_decreasing
        else:
            overfitting_detected = False

        # 记录分析结果
        with open(self.metrics_log_path, 'a') as f:
            f.write(f"\n=== Overfitting Analysis (Fold {fold}) ===\n")
            f.write(f"Final Training Loss: {final_train_loss:.4f}\n")
            f.write(f"Final Validation Loss: {final_val_loss:.4f}\n")
            f.write(f"Loss Gap (Val - Train): {loss_gap:.4f}\n")
            f.write(f"Best Validation Loss at Epoch: {best_val_epoch + 1}\n")
            f.write(f"Overfitting Detected: {'Yes' if overfitting_detected else 'No'}\n")

            # 提供建议
            if overfitting_detected:
                f.write("Recommendation: Consider early stopping, regularization, or data augmentation\n")
            elif loss_gap > 0.5:  # 较大的损失差距
                f.write("Recommendation: Model may be overfitting, consider reducing model complexity\n")
            else:
                f.write("Recommendation: Training appears well-balanced\n")

    def plot_combined_confusion_matrices(self, y_true, y_pred, phase='test', fold=0):
        """绘制所有类别的混淆矩阵在同一张图片上"""
        n_classes = len(self.class_names)
        rows = (n_classes + 2) // 3  # 每行3个，计算需要的行数
        cols = min(n_classes, 3)

        fig, axes = plt.subplots(rows, cols, figsize=(6 * cols, 5 * rows))
        if n_classes > 1:
            axes = axes.flatten()
        else:
            axes = [axes]

        for i, class_name in enumerate(self.class_names):
            ax = axes[i]
            true_class = y_true[:, i]
            pred_class = y_pred[:, i] > 0.5

            cm = confusion_matrix(true_class, pred_class)
            sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', ax=ax,
                        cbar=False, square=True)

            # 计算并显示F1分数
            f1 = f1_score(true_class, pred_class, zero_division=0)
            ax.set_title(f'{class_name}\nF1: {f1:.3f}', fontsize=12, fontweight='bold')
            ax.set_xlabel('Predicted')
            ax.set_ylabel('Actual')

        # 隐藏多余的子图
        for i in range(n_classes, len(axes)):
            axes[i].set_visible(False)

        plt.suptitle(f'Per-Class Confusion Matrices - {phase} (Fold {fold})',
                     fontsize=16, fontweight='bold', y=0.98)
        plt.tight_layout()

        # 保存图片
        cm_path = os.path.join(self.current_result_dir, f'combined_confusion_matrix.png')
        plt.savefig(cm_path, dpi=300, bbox_inches='tight')
        plt.close()

        return fig

