if __name__ == "__main__":
    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
    model = xresnet101(input_channels=12, num_classes=9).to(device)

    # Simulate ECG input: Batch=2, Leads=12, Length=5000
    x = torch.randn(2, 12, 5000).to(device)

    logits, attn = model(x)

    print(f"Model: XResNet101")
    print(f"Input: {x.shape}")
    print(f"Logits: {logits.shape}")  # Expected: [2, 9]
    print(f"Attention: {attn.shape}")  # Expected: [2, 1]

    # Calculate params
    total_params = sum(p.numel() for p in model.parameters())
