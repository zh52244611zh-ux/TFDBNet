import torch
import torch.nn as nn
import torch.nn.functional as F


class ResBlockWang(nn.Module):
    def __init__(self, in_channels, out_channels, kernels=(8, 5, 3), dropout=0.3):
        super(ResBlockWang, self).__init__()
        paddings = [(k - 1) // 2 for k in kernels]  # Standard same padding approx
        self.conv1 = nn.Conv1d(in_channels, out_channels, kernel_size=kernels[0], padding=paddings[0], bias=False)
        self.bn1 = nn.BatchNorm1d(out_channels)
        self.conv2 = nn.Conv1d(out_channels, out_channels, kernel_size=kernels[1], padding=paddings[1], bias=False)
        self.bn2 = nn.BatchNorm1d(out_channels)
        self.conv3 = nn.Conv1d(out_channels, out_channels, kernel_size=kernels[2], padding=paddings[2], bias=False)
        self.bn3 = nn.BatchNorm1d(out_channels)
        self.relu = nn.ReLU(inplace=True)
        self.dropout = nn.Dropout(p=dropout) if dropout > 0 else nn.Identity()

        # Shortcut connection
        self.shortcut = nn.Conv1d(in_channels, out_channels, kernel_size=1,
                                  bias=False) if in_channels != out_channels else nn.Identity()

    def forward(self, x):
        residual = self.shortcut(x)

        out = self.conv1(x)
        out = self.bn1(out)
        out = self.relu(out)
        out = self.dropout(out)

        out = self.conv2(out)
        out = self.bn2(out)
        out = self.relu(out)
        out = self.dropout(out)

        out = self.conv3(out)
        out = self.bn3(out)

        # Handle size mismatch by center cropping the larger tensor
        if out.shape[-1] != residual.shape[-1]:
            diff = abs(out.shape[-1] - residual.shape[-1])
            if out.shape[-1] > residual.shape[-1]:
                crop_start = diff // 2
                out = out[:, :, crop_start: crop_start + residual.shape[-1]]
            else:
                crop_start = diff // 2
                residual = residual[:, :, crop_start: crop_start + out.shape[-1]]

        out += residual
        out = self.relu(out)
        out = self.dropout(out)
        return out


class ResNetWang(nn.Module):
    """
    Enhanced ResNet for time series classification, based on
    Zhiguang Wang et al. (2017): "Time Series Classification from Scratch with Deep Neural Networks: A Strong Baseline".
    Increased complexity with more residual blocks, higher filter counts, added pooling layers, and dropout for multi-lead ECG classification.
    Input: batch x channels x seq_len
    """

    def __init__(self, input_channels=12, num_classes=9, dropout=0.3):
        super(ResNetWang, self).__init__()
        # Initial conv to expand channels
        self.init_conv = nn.Conv1d(input_channels, 128, kernel_size=7, stride=2, padding=3, bias=False)
        self.init_bn = nn.BatchNorm1d(128)
        self.init_relu = nn.ReLU(inplace=True)
        self.init_pool = nn.MaxPool1d(kernel_size=3, stride=2, padding=1)

        # Multiple residual blocks with progressive channels (128 -> 256 -> 512 -> 256)
        self.block1 = ResBlockWang(128, 128, kernels=(8, 5, 3), dropout=dropout)
        self.block2 = ResBlockWang(128, 256, kernels=(8, 5, 3), dropout=dropout)
        self.pool1 = nn.MaxPool1d(kernel_size=2, stride=2)  # Downsampling
        self.block3 = ResBlockWang(256, 512, kernels=(5, 3, 3), dropout=dropout)
        self.block4 = ResBlockWang(512, 256, kernels=(5, 3, 3), dropout=dropout)
        self.pool2 = nn.MaxPool1d(kernel_size=2, stride=2)  # Additional downsampling
        self.block5 = ResBlockWang(256, 128, kernels=(3, 3, 3), dropout=dropout)

        # Adaptive pooling (avg + max) for robust features
        self.adaptiveavgpool = nn.AdaptiveAvgPool1d(1)
        self.adaptivemaxpool = nn.AdaptiveMaxPool1d(1)

        # Final classifier
        self.fc = nn.Linear(128 * 2, num_classes)  # *2 for avg + max concat

    def forward(self, x):
        # x: (batch, input_channels, seq_len)
        x = self.init_conv(x)
        x = self.init_bn(x)
        x = self.init_relu(x)
        x = self.init_pool(x)

        x = self.block1(x)
        x = self.block2(x)
        x = self.pool1(x)
        x = self.block3(x)
        x = self.block4(x)
        x = self.pool2(x)
        x = self.block5(x)

        # Adaptive pooling
        x1 = self.adaptiveavgpool(x)
        x2 = self.adaptivemaxpool(x)
        x = torch.cat((x1, x2), dim=1)  # (batch, 128*2, 1)
        x = x.view(x.size(0), -1)  # (batch, 128*2)

        logits = self.fc(x)

        # Dummy attention as in original ResNet
        dummy_attention = torch.ones(x.size(0), 1).to(x.device)

        return logits, dummy_attention


# Compatibility with original ResNet calling
def resnet_wang(**kwargs):
    model = ResNetWang(**kwargs)
    return model


# Example usage (similar to resnet18)
if __name__ == "__main__":
    model = resnet_wang(input_channels=12, num_classes=9)
    print(model)

    x = torch.randn(4, 12, 5000)  # batch=4, 12 leads, seq_len=5000
    logits, attn = model(x)
    print("logits shape:", logits.shape)  # torch.Size([4, 9])
    print("attention shape:", attn.shape)  # torch.Size([4, 1])
